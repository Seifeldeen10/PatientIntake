FLASK_HOST=127.0.0.1
FLASK_PORT=5001
FLASK_DEBUG=0
APP_BASE_PATH=/patient-intake

SUBMISSIONS_PASSWORD=change_this_password

GEMINI_API_KEY=your_gemini_api_key
OPENFDA_API_KEY=your_openfda_api_key
DRUGBANK_API_KEY=

# Optional. Leave TESSERACT_CMD empty when the tesseract binary is on PATH.
# Linux EC2 example: /usr/bin/tesseract
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
TESSERACT_LANG=eng
TESSERACT_CONFIG=

DB_PATH=/home/ec2-user/PatientIntake/intake.db
UPLOAD_DIR=/home/ec2-user/PatientIntake/uploads
RAG_SOURCE_DIR=/home/ec2-user/PatientIntake/data/rag_files
RAG_CHROMA_DIR=/home/ec2-user/PatientIntake/chroma_db
